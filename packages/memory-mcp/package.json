{
  "name": "traqr-memory-mcp",
  "version": "0.2.3",
  "description": "Memory-as-a-service MCP server for AI agents. 11 tools, Postgres + pgvector, multi-strategy retrieval. Works with Claude Code, Cursor, Codex, and any MCP client.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "traqr-memory-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "setup.sql",
    "upgrade-*.sql",
    "README.md",
    "MEMORY_INSTRUCTIONS.md",
    "UPGRADING.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@traqr/memory": "^0.1.0",
    "zod": "^3.24.2"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "agent",
    "postgres",
    "pgvector",
    "embedding",
    "rag",
    "claude-code",
    "cursor",
    "codex"
  ],
  "license": "FSL-1.1-ALv2",
  "homepage": "https://traqr.dev/memory",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiggycapital/traqr-oss",
    "directory": "packages/memory-mcp"
  }
}
