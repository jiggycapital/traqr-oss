'use client'

/**
 * FilterToggle — Toggle button for filter/category selection
 * Generated by Traqr Init ({{DESIGN_FLAVOR}} flavor). Edit freely.
 *
 * Usage:
 *   <FilterToggle label="Active" active={filter === 'active'} onClick={() => setFilter('active')} />
 */

interface FilterToggleProps {
  label: string
  active: boolean
  onClick: () => void
  count?: number
  className?: string
}

export function FilterToggle({ label, active, onClick, count, className = '' }: FilterToggleProps) {
  return (
    <button
      onClick={onClick}
      className={`inline-flex items-center gap-1.5 {{DESIGN_RADIUS_MD}} px-3 py-1.5 text-sm font-medium design-transition ${
        active
          ? 'bg-design-primary text-white'
          : 'bg-design-card border border-design-border text-design-muted hover:text-design-fg hover:border-design-muted'
      } ${className}`}
    >
      {label}
      {count !== undefined && (
        <span
          className={`{{DESIGN_RADIUS_SM}} px-1.5 py-0.5 text-xs ${
            active
              ? 'bg-white/20 text-white'
              : 'bg-design-border text-design-muted'
          }`}
        >
          {count}
        </span>
      )}
    </button>
  )
}

/**
 * FilterToggleGroup — Row of filter toggles
 */
export function FilterToggleGroup({ children, className = '' }: { children: React.ReactNode; className?: string }) {
  return (
    <div className={`flex flex-wrap gap-2 ${className}`}>
      {children}
    </div>
  )
}
