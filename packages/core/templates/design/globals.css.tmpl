@import "tailwindcss";

{{#IF_DESIGN_DARK_MODE}}
@custom-variant dark (&:is(.dark *));
{{/IF_DESIGN_DARK_MODE}}

/* ============================================================
 * Design DNA — {{DESIGN_FLAVOR}} flavor
 * Generated by Traqr Init. Edit freely — this is your code now.
 * ============================================================ */

@theme inline {
  --color-design-primary: {{DESIGN_PRIMARY}};
  --color-design-secondary: {{DESIGN_SECONDARY}};
  --color-design-accent: {{DESIGN_ACCENT}};
  --color-design-bg: {{DESIGN_BG}};
  --color-design-fg: {{DESIGN_FG}};
  --color-design-card: {{DESIGN_CARD}};
  --color-design-border: {{DESIGN_BORDER}};
  --color-design-muted: {{DESIGN_MUTED}};

  --font-sans: '{{DESIGN_FONT_SANS}}', ui-sans-serif, system-ui, sans-serif;
  --font-mono: '{{DESIGN_FONT_MONO}}', ui-monospace, monospace;
}

/* ---- Base ---- */

:root {
  background-color: var(--color-design-bg);
  color: var(--color-design-fg);
}

{{#IF_DESIGN_DARK_MODE}}
/* ---- Dark mode overrides ---- */

.dark {
  --color-design-bg: {{DESIGN_DARK_BG}};
  --color-design-fg: {{DESIGN_DARK_FG}};
  --color-design-card: {{DESIGN_DARK_CARD}};
  --color-design-border: {{DESIGN_DARK_BORDER}};
  --color-design-muted: {{DESIGN_DARK_MUTED}};

  background-color: var(--color-design-bg);
  color: var(--color-design-fg);
}
{{/IF_DESIGN_DARK_MODE}}

/* ---- Scrollbar ---- */

::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--color-design-border);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--color-design-muted);
}

/* ---- Shadow utilities ---- */

{{#IF_DESIGN_SHADOWS_SOFT}}
.design-shadow-sm {
  box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.03);
}
.design-shadow-md {
  box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.05), 0 1px 2px -1px rgb(0 0 0 / 0.05);
}
.design-shadow-lg {
  box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05);
}
{{/IF_DESIGN_SHADOWS_SOFT}}

{{#IF_DESIGN_SHADOWS_MEDIUM}}
.design-shadow-sm {
  box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.08), 0 1px 2px -1px rgb(0 0 0 / 0.08);
}
.design-shadow-md {
  box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
}
.design-shadow-lg {
  box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
}
{{/IF_DESIGN_SHADOWS_MEDIUM}}

{{#IF_DESIGN_SHADOWS_DRAMATIC}}
.design-shadow-sm {
  box-shadow: 0 2px 8px -2px color-mix(in srgb, var(--color-design-primary) 15%, transparent);
}
.design-shadow-md {
  box-shadow: 0 4px 14px -3px color-mix(in srgb, var(--color-design-primary) 20%, transparent);
}
.design-shadow-lg {
  box-shadow: 0 8px 25px -5px color-mix(in srgb, var(--color-design-primary) 25%, transparent),
              0 0 20px -5px color-mix(in srgb, var(--color-design-secondary) 10%, transparent);
}
{{/IF_DESIGN_SHADOWS_DRAMATIC}}

/* ---- Typography ---- */

body {
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

code, pre, kbd {
  font-family: var(--font-mono);
}

/* ---- Animations ---- */

{{#IF_DESIGN_ANIMATIONS}}
@keyframes design-fade-up {
  from {
    opacity: 0;
    transform: translateY({{DESIGN_ENTRANCE_Y}});
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes design-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes design-progress {
  from { width: 0%; }
  to { width: 100%; }
}

.design-animate-in {
  animation: design-fade-up {{DESIGN_TRANSITION_DURATION}} ease-out both;
}

.design-shimmer {
  background: linear-gradient(
    90deg,
    var(--color-design-card) 25%,
    var(--color-design-border) 50%,
    var(--color-design-card) 75%
  );
  background-size: 200% 100%;
  animation: design-shimmer 1.5s ease-in-out infinite;
}
{{/IF_DESIGN_ANIMATIONS}}

/* ---- Transitions ---- */

.design-transition {
  transition-property: color, background-color, border-color, box-shadow, opacity, transform;
  transition-duration: {{DESIGN_TRANSITION_DURATION}};
  transition-timing-function: ease-out;
}

.design-hover-lift:hover {
  transform: translateY({{DESIGN_HOVER_LIFT}});
}

.design-hover-scale:hover {
  transform: scale({{DESIGN_HOVER_SCALE}});
}

/* ---- Reduced motion ---- */

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
