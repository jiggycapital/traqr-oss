# Read existing config or start fresh
if [ -f ~/.traqr/config.json ]; then
  EXISTING=$(cat ~/.traqr/config.json)
else
  EXISTING='{}'
fi

# Use node to upsert the project entry (safe JSON manipulation)
node -e "
  const cfg = $EXISTING;
  if (!cfg.projects) cfg.projects = {};
