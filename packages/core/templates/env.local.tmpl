#
# Copy this file to .env.local and fill in your values.
# Only uncomment what you need for your tier.
#
# Your tier: {{STARTER_PACK}} (Tier {{TIER}})
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Core: Supabase (All Tiers) ──────────────────────────────
# Your database + auth backend
# Find these at: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Traqr Internal (All Tiers) ──────────────────────────────
# Secret for authenticated cron endpoints
# Generate one: openssl rand -hex 32
CRON_SECRET=
# Base URL for Traqr API calls (usually your app's URL)
TRAQR_API_BASE=http://localhost:3000/api
# Multi-project identity
TRAQR_PROJECT_SLUG={{TRAQR_PROJECT_SLUG}}
NEXT_PUBLIC_TRAQR_PROJECT_SLUG={{TRAQR_PROJECT_SLUG}}
TRAQR_CHANNEL_PREFIX={{SLACK_CHANNEL_PREFIX}}

{{#IF_TIER_1+}}
# ─── Memory System (Tier 1+: Smart Dev) ─────────────────────
# Traqr's vector memory database for learning persistence
# These point to the Supabase project hosting your memory schema
# (can be the same as your main Supabase project)
TRAQR_SUPABASE_URL=
TRAQR_SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — Powers semantic search embeddings
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Memory table name (default: 'memories')
# Only change if sharing a Supabase project across multiple Traqr instances
# TRAQR_MEMORY_TABLE=memories
{{/IF_TIER_1+}}

{{#IF_ISSUES}}
# ─── Linear (Tier 2+: Production) ───────────────────────────
# Issue tracking + ticket automation
# Get your key at: https://linear.app → Settings → API → Personal API keys
LINEAR_API_KEY=
# Ticket prefix for this project's Linear team (e.g., NTQ, TD)
TRAQR_TICKET_PREFIX={{TICKET_PREFIX}}

# ─── GitHub (Tier 2+: Production) ───────────────────────────
# PR automation, webhook handling
# Create a token at: https://github.com/settings/tokens (classic, repo scope)
GITHUB_TOKEN=
# Webhook secret for GitHub → your app integration
# Generate one: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=
{{/IF_ISSUES}}

{{#IF_SLACK}}
# ─── Slack (Tier 3+: Full Traqr) ────────────────────────────
# Bot notifications, PR alerts, daemon coordination
# Create a Slack app at: https://api.slack.com/apps
# Required scopes: chat:write, channels:read, reactions:write
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
{{/IF_SLACK}}

{{#IF_POSTHOG}}
# ─── PostHog (Tier 4: Full Traqr) ───────────────────────────
# Product analytics + feature flags
# Find these at: https://us.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
{{/IF_POSTHOG}}

{{#IF_SENTRY}}
# ─── Sentry (Error Tracking) ────────────────────────────────
# Catch errors before your users do
# Find these at: https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
{{/IF_SENTRY}}

{{#IF_EMAIL}}
# ─── Email via Resend ───────────────────────────────────────
# Transactional email (signup confirmations, notifications)
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
{{/IF_EMAIL}}

{{#IF_TIER_3+}}
# ─── Vercel KV (Tier 3+) ────────────────────────────────────
# Key-value store for daemon coordination, rate limiting, state
# Auto-provisioned in Vercel dashboard → Storage → KV
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_URL=
{{/IF_TIER_3+}}

{{#IF_GUARDIAN}}
# ─── Guardian (Auto-Merge Daemon) ───────────────────────────
# Controls the autonomous PR lifecycle manager
# Set GUARDIAN_ENABLED=true when you're ready for auto-merge
GUARDIAN_ENABLED=false
GUARDIAN_DRY_RUN=true
GUARDIAN_CI_AUTOFIX=false
{{/IF_GUARDIAN}}

{{#IF_CRONS}}
# ─── Cron Jobs ──────────────────────────────────────────────
# Vercel cron endpoints use CRON_SECRET (defined above) for auth.
# No additional env vars needed — just configure vercel.json crons.
{{/IF_CRONS}}

